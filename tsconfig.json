{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@urk/core": ["packages/core/src"],
      "@urk/core/*": ["packages/core/src/*"],
      "@urk/adapters": ["packages/adapters/src"],
      "@urk/adapters/*": ["packages/adapters/src/*"],
      "@urk/examples": ["packages/examples/src"],
      "@urk/examples/*": ["packages/examples/src/*"],
      "@urk/react-urk": ["packages/react-urk/src"],
      "@urk/react-urk/*": ["packages/react-urk/src/*"],
      "@urk/next-urk": ["packages/next-urk/src"],
      "@urk/next-urk/*": ["packages/next-urk/src/*"]
    }
  },
  "include": ["packages/*/src"],
  "exclude": ["node_modules", "dist"]
}
