{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@urk/core": ["../../packages/core/src"],
      "@urk/core/*": ["../../packages/core/src/*"],
      "@urk/adapters": ["../../packages/adapters/src"],
      "@urk/adapters/*": ["../../packages/adapters/src/*"],
      "@urk/examples": ["../../packages/examples/src"],
      "@urk/examples/*": ["../../packages/examples/src/*"]
    }
  }
}
