---
/**
 * Company: EonHive Inc.
 * Title: Site Footer
 * Purpose: Render the shared footer links and boundary summary for the URK public website.
 * Author: Stan Nesi
 * Created: 2026-05-01
 * Updated: 2026-05-01
 * Notes: Vibe coded with Codex.
 */

import BrandLogo from '@/components/visuals/BrandLogo.astro';
import { siteMetadata } from '@/data/site';
---

<footer class="site-footer">
  <div class="site-shell site-footer__inner">
    <div class="site-footer__meta">
      <BrandLogo variant="horizontal" className="site-footer__logo" />
      <div class="site-footer__tagline">{siteMetadata.tagline}</div>
    </div>

    <nav class="site-footer__links" aria-label="Footer">
      <a href="/docs">Docs</a>
      <a href="/examples">Examples</a>
      <a href="/packages">Packages</a>
      <a href={siteMetadata.brandPath}>Brand</a>
      <a href={siteMetadata.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
    </nav>
  </div>
</footer>
